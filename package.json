{
  "name": "flare-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "nuxt build",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply flaredocs-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply flaredocs-db --remote",
    "dev": "nuxt dev",
    "lint": "eslint app db *.ts *.mjs",
    "lint:fix": "eslint app db *.ts *.mjs --fix",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "project:setup": "node --experimental-strip-types scripts/setup.ts",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/vue-next": "^1.22.0",
    "@nuxt/eslint": "latest",
    "@nuxt/ui": "latest",
    "bytemd": "^1.22.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "katex": "^0.16.22",
    "markdown-it": "^14.1.1",
    "nuxt": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@types/markdown-it": "^14.1.2",
    "autoprefixer": "latest",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "postcss": "latest",
    "prettier": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vue-tsc": "^3.1.2",
    "wrangler": "^4.70.0"
  }
}
