# Runtime
NUXT_AUTH_SECRET=replace-with-a-long-random-secret
# Optional: one-time bootstrap for initial admin account seeding (`admin` username)
NUXT_BOOTSTRAP_ADMIN_PASSWORD=

# Optional setup helper inputs
SETUP_D1_DATABASE_ID=replace-with-your-d1-database-id
SETUP_R2_BUCKET=replace-with-your-r2-bucket
SETUP_R2_PREVIEW_BUCKET=flaredocs-assets-preview
